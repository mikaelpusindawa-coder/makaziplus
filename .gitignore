# Dependencies
node_modules/
*/node_modules/

# Environment files — NEVER commit these
.env
server/.env
client/.env
*.env.local

# Build outputs
client/build/
dist/
Production_URLs.txt/

# Uploaded files — don't commit user uploads
server/uploads/*
!server/uploads/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Misc
coverage/
.nyc_output/
