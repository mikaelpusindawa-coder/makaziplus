{
  "name": "makaziplus",
  "version": "2.0.0",
  "description": "MakaziPlus - Tanzania's #1 Property Platform",
  "scripts": {
    "setup":       "node setup.js",
    "dev":         "concurrently \"npm run server\" \"npm run client\"",
    "server":      "cd server && npm run dev",
    "client":      "cd client && npm start",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "start":       "npm run install-all && npm run setup && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  }
}
